# Security - NEVER commit real secrets
# appsettings.Development.json contains dev secrets
src/DentalID.Desktop/appsettings.Development.json

# ONNX Model files (large binary files - exceed GitHub's 100MB limit)
# Store models separately and download before running
models/*.onnx
models/buffalo_l/*.onnx
models/export_model.py
# Desktop embedded models (also large)
src/DentalID.Desktop/Models/*.onnx
**/*.onnx

# Debug/Test output files
debug_tool_output*.txt
detection_debug*.txt
run_log_verbose.txt
output.log
TestResolveViewModel.cs

# Panoramic dataset images (large dataset - store externally)
Panoramic Dental Xray Dataset/

# Published output
publish.ps1

# Benchmark results
src/DentalID.Benchmark/benchmark_results_*.csv

# Test runtime data
tests/*/bin/Debug/net8.0/data/
tests/DebugTool/
tests/BatchXrayTest/
tests/BatchXrayTest.csx

