<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DentalID.Desktop.App"
             xmlns:local="using:DentalID.Desktop">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <!-- 
                THEME: Fluent Professional (Forensic Suite v7.0)
                A neutral, professional, Microsoft Fluent-aligned gray theme.
            -->
            <!-- 🎨 PALETTE -->
             <!-- Backgrounds -->
             <SolidColorBrush x:Key="SurfaceDeepBrush" Color="#0D0E12" />      <!-- Deep Graphite -->
             <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#16181D" />  <!-- Elevated Panels -->
             <SolidColorBrush x:Key="SurfaceFloatingBrush" Color="#1E2127" />  <!-- Input Fields/Hovers -->
             <SolidColorBrush x:Key="SurfaceBgBrush" Color="#101216" />        <!-- Background -->
             <SolidColorBrush x:Key="CardBgBrush" Color="#16181D" />           <!-- Card Background -->
             <SolidColorBrush x:Key="InputBgBrush" Color="#1A1D23" />          <!-- Input Background -->
             
             <SolidColorBrush x:Key="PageBgBrush" Color="Transparent" />       <!-- Transparent for Window Effects -->
             <SolidColorBrush x:Key="SidebarBgBrush" Color="#E50D0F14" />      <!-- 88% Opacity Graphite -->
            
             <!-- Accents (Steel Blue family) -->
             <Color x:Key="AccentPrimaryColor">#00E5FF</Color>
             <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#00E5FF" />    <!-- Steel Blue -->
             <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#00B8D4" />  <!-- Soft Sky -->
             <SolidColorBrush x:Key="AccentTertiaryBrush" Color="#00838F" />   <!-- Muted Tertiary -->
             <SolidColorBrush x:Key="AccentBlueBrush" Color="#00E5FF" />       <!-- Alias -->
             <SolidColorBrush x:Key="AccentBlueDarkBrush" Color="#006064" />   <!-- Pressed/Dark -->
             <SolidColorBrush x:Key="AccentRedBrush" Color="#FF3D00" />        <!-- Red for danger buttons -->
             <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF9100" />     <!-- Orange accent -->
             <SolidColorBrush x:Key="AccentPurpleBrush" Color="#D500F9" />     <!-- Purple accent -->
             <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="#18FFFF" />   <!-- Primary button hover -->
             <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="#00B8D4" /> <!-- Primary button pressed -->

             <!-- Functional Colors (Muted Professional) -->
             <SolidColorBrush x:Key="SuccessBrush" Color="#00E676" />          <!-- Xbox Green -->
             <SolidColorBrush x:Key="WarningBrush" Color="#FFD600" />          <!-- Orange -->
             <SolidColorBrush x:Key="ErrorBrush" Color="#FF1744" />            <!-- Red -->
             <SolidColorBrush x:Key="ForensicWarningBrush" Color="#FF1744" />  
             <SolidColorBrush x:Key="ForensicSuccessBrush" Color="#00E676" />
             <SolidColorBrush x:Key="AccentGreenBrush" Color="#00E676" />      <!-- For cases grid -->  
            
             <!-- Text -->
             <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF" />      <!-- White -->
             <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D0D0D0" />    <!-- Light Gray -->
             <SolidColorBrush x:Key="TextDisabledBrush" Color="#707070" />     <!-- Darker Gray -->
             <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />     <!-- White -->
             <SolidColorBrush x:Key="TextMutedBrush" Color="#808080" />       <!-- Muted Gray -->

            <!-- Borders -->
            <SolidColorBrush x:Key="BorderPrimaryBrush" Color="#3A414A" />    <!-- Standard Border -->
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="#262A33" />     <!-- Subtle Border -->
            <SolidColorBrush x:Key="BorderSecondaryBrush" Color="#1A1D23" />  <!-- Secondary Border -->
            <SolidColorBrush x:Key="BorderFocusBrush" Color="#00E5FF" />      <!-- Focus Border -->
            <SolidColorBrush x:Key="BorderInputBrush" Color="#3A414A" />      <!-- Input Border -->

            <!-- Navigation -->
            <SolidColorBrush x:Key="NavItemHoverBrush" Color="#2E343C" />
            <SolidColorBrush x:Key="NavItemSelectedBrush" Color="#354A5D6E" /> <!-- Subtle Selected -->
            <SolidColorBrush x:Key="NavItemSelectedTextBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="NavItemTextBrush" Color="#B9C1CA" />
            <SolidColorBrush x:Key="NavItemHoverTextBrush" Color="#FFFFFF" />

            <!-- 🖋 TYPOGRAPHY -->
            <FontFamily x:Key="FontSans">Segoe UI, Inter, Roboto, Helvetica Neue, Arial</FontFamily>
            <FontFamily x:Key="FontMono">JetBrains Mono, Consolas, Menlo, Monospace</FontFamily>
            
            <!-- Standard Icons (MDL2 style approximation) -->
