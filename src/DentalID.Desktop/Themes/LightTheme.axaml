<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════
         DentalID — GitHub Light Theme Override
         Overrides the default Fluent-gray palette in App.axaml
         with a clean GitHub-inspired light aesthetic.
    ═══════════════════════════════════════════════════════ -->

    <!-- ── Backgrounds ───────────────────────────────────── -->
    <SolidColorBrush x:Key="SurfaceDeepBrush"     Color="#F6F8FA"/>  <!-- Page root -->
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#FFFFFF"/>  <!-- Cards / panels -->
    <SolidColorBrush x:Key="SurfaceFloatingBrush" Color="#EEF1F5"/>  <!-- Dropdowns / overlays -->
    <SolidColorBrush x:Key="SurfaceBgBrush"       Color="#F0F2F5"/>
    <SolidColorBrush x:Key="CardBgBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBgBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PageBgBrush"          Color="#F6F8FA"/>
    <SolidColorBrush x:Key="SidebarBgBrush"       Color="#E8FFFFFF"/> <!-- 91% opacity white -->

    <!-- ── Accent Colors ─────────────────────────────────── -->
    <Color x:Key="AccentPrimaryColor">#0969DA</Color>
    <SolidColorBrush x:Key="AccentPrimaryBrush"        Color="#0969DA"/> <!-- GitHub Blue -->
    <SolidColorBrush x:Key="AccentPrimaryHoverBrush"   Color="#0860CA"/>
    <SolidColorBrush x:Key="AccentPrimaryPressedBrush" Color="#0550AE"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush"      Color="#0550AE"/> <!-- Dark blue -->
    <SolidColorBrush x:Key="AccentTertiaryBrush"       Color="#8250DF"/> <!-- Purple -->
    <SolidColorBrush x:Key="AccentBlueBrush"           Color="#0969DA"/>
    <SolidColorBrush x:Key="AccentBlueDarkBrush"       Color="#0550AE"/>
    <SolidColorBrush x:Key="AccentRedBrush"            Color="#CF222E"/>
    <SolidColorBrush x:Key="AccentOrangeBrush"         Color="#BF8700"/>
    <SolidColorBrush x:Key="AccentPurpleBrush"         Color="#8250DF"/>
    <SolidColorBrush x:Key="AccentGreenBrush"          Color="#1A7F37"/>

    <!-- ── Functional Status ─────────────────────────────── -->
    <SolidColorBrush x:Key="SuccessBrush"         Color="#1A7F37"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="#BF8700"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="#CF222E"/>
    <SolidColorBrush x:Key="ForensicWarningBrush" Color="#CF222E"/>
    <SolidColorBrush x:Key="ForensicSuccessBrush" Color="#1A7F37"/>

    <!-- ── Text ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1F2328"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#424A53"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="#656D76"/>
    <SolidColorBrush x:Key="TextDisabledBrush"  Color="#8C959F"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

    <!-- ── Borders ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderPrimaryBrush"   Color="#D0D7DE"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"    Color="#E1E4E8"/>
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="#E1E4E8"/>
    <SolidColorBrush x:Key="BorderFocusBrush"     Color="#0969DA"/>
    <SolidColorBrush x:Key="BorderInputBrush"     Color="#D0D7DE"/>

    <!-- ── Navigation ───────────────────────────────────── -->
    <SolidColorBrush x:Key="NavItemHoverBrush"        Color="#EEF1F5"/>
    <SolidColorBrush x:Key="NavItemSelectedBrush"     Color="#0969DA"/>
    <SolidColorBrush x:Key="NavItemSelectedTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavItemTextBrush"         Color="#656D76"/>
    <SolidColorBrush x:Key="NavItemHoverTextBrush"    Color="#1F2328"/>

</ResourceDictionary>
