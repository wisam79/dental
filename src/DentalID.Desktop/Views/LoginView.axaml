<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DentalID.Desktop.ViewModels"
             xmlns:conv="clr-namespace:DentalID.Desktop.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="DentalID.Desktop.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Grid>
        <!-- Background: Cyber/Forensic Gradient -->
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="50%,50%" GradientOrigin="50%,50%" RadiusX="100%" RadiusY="100%">
                    <GradientStop Color="#1a1a2e" Offset="0"/>
                    <GradientStop Color="#000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        
        <!-- Subtle Grid Pattern Overlay -->
        <Canvas Opacity="0.05">
            <!-- Can be replaced with a proper tiled image brush later -->
            <Path Data="M0,0 L100,0 L100,100 L0,100 Z M5,5 L95,5 L95,95 L5,95 Z" Fill="#FFFFFF" Width="1920" Height="1080" Stretch="UniformToFill"/>
        </Canvas>

        <!-- Main Content Area -->
        <Grid ColumnDefinitions="*, 480">
            
            <!-- Left Side: Branding / Hero -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <PathIcon Data="{StaticResource IconFingerprint}" Width="120" Height="120" Foreground="{DynamicResource AccentPrimaryBrush}" Opacity="0.8">
                    <PathIcon.Effect>
                        <!-- <DropShadowEffect Color="{StaticResource AccentPrimaryColor}" BlurRadius="30" Opacity="0.4"/> -->
                    </PathIcon.Effect>
                </PathIcon>
                
                <TextBlock Text="DENTAL ID" FontSize="48" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" LetterSpacing="4" HorizontalAlignment="Center"/>
                <TextBlock Text="FORENSIC INVESTIGATION SUITE v7.0" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" LetterSpacing="2" HorizontalAlignment="Center"/>
                
                <Border Background="{DynamicResource AccentPrimaryBrush}" Height="2" Width="100" HorizontalAlignment="Center" Opacity="0.5"/>
                
                <TextBlock Text="SECURE. INTELLIGENT. PRECISE." FontSize="14" Foreground="{DynamicResource TextMutedBrush}" FontStyle="Italic" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Right Side: Login Form (Glassmorphism) -->
            <Border Grid.Column="1" Background="#10FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0">
                <Grid>
                    <!-- Frosted Glass Effect Layer (Simulated with semi-transparent background) -->
                    <Border Background="#D0151515" /> 

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="60" Spacing="25">
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="{DynamicResource Str_Login_Title}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Please authenticate to access the system case files." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Username -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="OPERATOR ID" Classes="label" FontWeight="Bold" LetterSpacing="1"/>
                            <TextBox Text="{Binding Username}" 
                                     Watermark="{DynamicResource Str_Login_UserPlace}" 
                                     IsEnabled="{Binding !IsBusy}"
                                     Height="45"
                                     VerticalContentAlignment="Center"
                                     TextWrapping="NoWrap"/>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="SECURITY TOKEN" Classes="label" FontWeight="Bold" LetterSpacing="1"/>
                            <Grid>
                                <TextBox Name="PasswordBox"
                                         Text="{Binding Password}"
                                         Watermark="{DynamicResource Str_Login_PassPlace}"
                                         IsEnabled="{Binding !IsBusy}"
                                         IsVisible="{Binding !ShowPassword}"
                                         Height="45"
                                         VerticalContentAlignment="Center"
                                         PasswordChar="●"/>
                                <TextBox Text="{Binding Password}" 
                                         Watermark="{DynamicResource Str_Login_PassPlace}"
                                         IsEnabled="{Binding !IsBusy}"
                                         IsVisible="{Binding ShowPassword}"
                                         Height="45"
                                         VerticalContentAlignment="Center"/>
                                <Button Command="{Binding TogglePasswordVisibilityCommand}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Classes="ghost"
                                        Padding="8"
                                        IsEnabled="{Binding !IsBusy}">
                                    <PathIcon Data="{Binding ShowPassword, Converter={x:Static conv:BoolToIconConverter.Instance}}" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Error Message -->
                         <Border Background="#20FF0000" BorderBrush="#80FF0000" BorderThickness="1" CornerRadius="4" Padding="10"
                                IsVisible="{Binding ErrorMessage, Converter={x:Static conv:StringToBoolConverter.Instance}}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{StaticResource IconWarning}" Foreground="#FF6666" Width="16" Height="16"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6666" TextWrapping="Wrap" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Login Button -->
                        <Button Command="{Binding LoginCommand}" 
                                Content="{DynamicResource Str_Login_Button}" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Center"
                                Classes="primary"
                                Height="50"
                                FontSize="16"
                                IsEnabled="{Binding !IsBusy}"/>

                         <!-- Forgot Password -->
                        <Button Command="{Binding ForgotPasswordCommand}"
                                Content="{DynamicResource Str_Login_Forgot}"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Classes="ghost"
                                IsEnabled="{Binding !IsBusy}"/>
                        
                        <!-- Progress -->
                        <ProgressBar IsIndeterminate="True" 
                                     IsVisible="{Binding IsBusy}" 
                                     Height="2"
                                     Foreground="{DynamicResource AccentPrimaryBrush}"
                                     Background="#30FFFFFF"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,20,0,0">
                             <PathIcon Data="{StaticResource IconPower}" Width="12" Height="12" Foreground="{DynamicResource TextMutedBrush}"/>
                             <TextBlock Text="System Secure. Enforced by DentalID Guard." FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
