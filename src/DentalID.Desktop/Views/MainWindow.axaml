<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:DentalID.Desktop.Views"
        xmlns:svc="using:DentalID.Desktop.Services"
        xmlns:conv="using:DentalID.Desktop.Converters"
        x:Class="DentalID.Desktop.Views.MainWindow"
        Title="DentalID"
        Icon="/Assets/Brand/dental.png"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="False"
        ExtendClientAreaChromeHints="Default"
        TransparencyLevelHint="None"
        Background="#101216"
        FlowDirection="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToFlowDirectionConverter.Instance}}">

    
    <Grid>
        <views:MainView />
    </Grid>
</Window>
