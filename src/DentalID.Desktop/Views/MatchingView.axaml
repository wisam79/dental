<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DentalID.Desktop.ViewModels"
             xmlns:svc="using:DentalID.Desktop.Services"
             xmlns:conv="using:DentalID.Desktop.Converters"
             xmlns:viewcontrols="using:DentalID.Desktop.Views.Controls"
             x:Class="DentalID.Desktop.Views.MatchingView"
             x:DataType="vm:MatchingViewModel"
             x:Name="Root">

    <!--
    ════════════════════════════════════════════════════
      MATCHING VIEW  — Forensic Comparison Studio
      Fixed:
        • Removed duplicate local Styles section
        • IconList  → IconSubjects (available in App.axaml)
        • PrimaryBrush → AccentPrimaryBrush
        • labGhost/labPrimary/labSuccess → global classes
    ════════════════════════════════════════════════════
    -->

    <Grid RowDefinitions="Auto,*" Margin="0,0,0,0">

        <!-- ══════ PAGE HEADER ══════ -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Classes="h1"
                           Text="{DynamicResource Str_Nav_Matching}"
                           Margin="0,0,0,4"/>
                <TextBlock Classes="caption"
                           Text="{DynamicResource Str_Match_Desc}"/>
            </StackPanel>
        </Grid>

        <!-- ══════ TWO-COLUMN LAYOUT ══════ -->
        <Grid Grid.Row="1" ColumnDefinitions="1.05*,1.35*">

            <!-- ─── LEFT: Comparison Studio ─── -->
            <Border Grid.Column="0"
                    MinWidth="320"
                    Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,12,0'}"
                    Classes="card"
                    Padding="20">
                <DockPanel>

                    <!-- Studio header -->
                    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{StaticResource IconAnalysis}"
                                      Foreground="{DynamicResource AccentPrimaryBrush}"
                                      Width="16" Height="16"/>
                            <TextBlock Classes="h3"
                                       Text="{DynamicResource Str_Match_StudioTitle}"
                                       LetterSpacing="0.5"/>
                        </StackPanel>

                        <!-- Overlay tools row (visible only when query loaded) -->
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding IsQueryLoaded}"
                              Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{DynamicResource Str_Match_Opacity}"
                                           Classes="caption"
                                           VerticalAlignment="Center"/>
                                <Slider Minimum="0" Maximum="1"
                                        Value="{Binding OverlayOpacity}"
                                        IsEnabled="{Binding IsOverlayMode}"
                                        Width="120"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          OnContent="{DynamicResource Str_Match_ModeOverlay}"
                                          OffContent="{DynamicResource Str_Match_ModeSplit}"
                                          IsChecked="{Binding IsOverlayMode}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Bottom action panel -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="10">

                        <!-- Load query image -->
                        <Button Command="{Binding BrowseQueryImageCommand}"
                                HorizontalAlignment="Stretch"
                                Classes="outline">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconFolderOpen}"
                                          Width="14" Height="14"/>
                                <TextBlock Text="{DynamicResource Str_Match_LoadQuery}"/>
                            </StackPanel>
                        </Button>

                        <!-- Run matching -->
                        <Button Command="{Binding RunMatchingCommand}"
                                IsEnabled="{Binding IsQueryLoaded}"
                                HorizontalAlignment="Stretch"
                                Classes="primary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconMatching}"
                                          Width="14" Height="14"/>
                                <TextBlock Text="{DynamicResource Str_Match_Run}"/>
                            </StackPanel>
                        </Button>

                        <Border Classes="badge-info" Padding="10,8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <PathIcon Data="{StaticResource IconInfo}"
                                          Width="14" Height="14"
                                          Foreground="{DynamicResource AccentPrimaryBrush}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusMessage}"
                                           Classes="caption"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding MatchingProgress, StringFormat='{}{0}%'}"
                                           Classes="mono caption"
                                           IsVisible="{Binding IsMatching}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Classes="shimmer"
                                     Height="4"
                                     IsVisible="{Binding IsMatching}"/>

                        <!-- Query fingerprint status badge -->
                        <Border Classes="badge-info"
                                IsVisible="{Binding IsQueryLoaded}"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconFingerprint}"
                                          Width="14" Height="14"
                                          Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource Str_Match_QueryFingerprint}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource SuccessBrush}"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding QueryVector, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="{DynamicResource Str_Match_VectorExtracted}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ── Image Viewport ── -->
                    <Border Background="{DynamicResource SurfaceDeepBrush}"
                            CornerRadius="8"
                            Margin="0,0,0,12"
                            ClipToBounds="True"
                            MinHeight="240">
                        <Panel>

                            <!-- Empty state -->
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="10"
                                        IsVisible="{Binding !IsQueryLoaded}">
                                <PathIcon Data="{StaticResource IconTooth}"
                                          Width="48" Height="48"
                                          HorizontalAlignment="Center"
                                          Foreground="{DynamicResource TextDisabledBrush}"/>
                                <TextBlock Text="{DynamicResource Str_Match_NoImage}"
                                           Classes="caption"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Images -->
                            <viewcontrols:AdvancedImageViewer IsVisible="{Binding IsQueryLoaded}">
                                <viewcontrols:AdvancedImageViewer.InnerContent>
                                    <Grid>
                                        <!-- Overlay Mode -->
                                        <Grid IsVisible="{Binding IsOverlayMode}">
                                            <Image Source="{Binding QueryImagePath, Converter={x:Static vm:BitmapAssetValueConverter.Instance}}"
                                                   Stretch="Uniform"
                                                   Opacity="1.0"/>
                                            <Image Source="{Binding TargetImagePath, Converter={x:Static vm:BitmapAssetValueConverter.Instance}}"
                                                   Stretch="Uniform"
                                                   Opacity="{Binding OverlayOpacity}"
                                                   IsVisible="{Binding TargetImagePath, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        </Grid>

                                        <!-- Split Mode -->
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="2"
                                              IsVisible="{Binding IsOverlayMode, Converter={x:Static BoolConverters.Not}}">
                                            <Border Background="{DynamicResource SurfaceFloatingBrush}">
                                                <Image Source="{Binding QueryImagePath, Converter={x:Static vm:BitmapAssetValueConverter.Instance}}"
                                                       Stretch="Uniform"/>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Background="{DynamicResource SurfaceFloatingBrush}"
                                                    IsVisible="{Binding TargetImagePath, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                <Image Source="{Binding TargetImagePath, Converter={x:Static vm:BitmapAssetValueConverter.Instance}}"
                                                       Stretch="Uniform"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Spacing="6"
                                                        IsVisible="{Binding TargetImagePath, Converter={x:Static ObjectConverters.IsNull}}">
                                                <PathIcon Data="{StaticResource IconSubjects}"
                                                          Width="20" Height="20"
                                                          Foreground="{DynamicResource TextDisabledBrush}"/>
                                                <TextBlock Text="{DynamicResource Str_Match_NoCandidates}"
                                                           Classes="caption"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </viewcontrols:AdvancedImageViewer.InnerContent>
                            </viewcontrols:AdvancedImageViewer>

                            <!-- Matching progress overlay -->
                            <Border Background="{DynamicResource OverlayStrongBrush}"
                                    IsVisible="{Binding IsMatching}">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="14">
                                    <ProgressBar Value="{Binding MatchingProgress}"
                                                 Maximum="100"
                                                 Width="200"
                                                 Classes="thick"/>
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               MaxWidth="280"
                                               HorizontalAlignment="Center"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>

                        </Panel>
                    </Border>

                </DockPanel>
            </Border>

            <!-- ─── RIGHT: Results / Candidates ─── -->
            <Border Grid.Column="1"
                    Classes="card"
                    Padding="20">
                <DockPanel>

                    <!-- Results header -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Spacing="10"
                                Margin="0,0,0,16">
                        <PathIcon Data="{StaticResource IconSubjects}"
                                  Foreground="{DynamicResource AccentSecondaryBrush}"
                                  Width="16" Height="16"/>
                        <TextBlock Classes="h3"
                                   Text="{DynamicResource Str_Match_CandidatesTitle}"
                                   LetterSpacing="0.5"/>
                        <Border Classes="badge badge-info" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource IconMatching}"
                                          Width="11" Height="11"
                                          Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                <TextBlock Text="{Binding Candidates.Count}"
                                           Classes="caption"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="badge"
                                Background="{DynamicResource OverlayHoverBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                IsVisible="{Binding SelectedCase, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock Classes="caption">
                                <Run Text="{Binding SelectedCase.CaseNumber}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Bottom: Link case + confirm -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Spacing="10">
                        <ComboBox ItemsSource="{Binding ActiveCases}"
                                  SelectedItem="{Binding SelectedCase}"
                                  PlaceholderText="{DynamicResource Str_Match_LinkCase}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding CaseNumber}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Command="{Binding ConfirmMatchCommand}"
                                IsEnabled="{Binding SelectedCandidate, Converter={x:Static ObjectConverters.IsNotNull}}"
                                HorizontalAlignment="Stretch"
                                Classes="success">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource IconCheck}"
                                          Width="14" Height="14"/>
                                <TextBlock Text="{DynamicResource Str_Match_Confirm}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Candidates list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ListBox ItemsSource="{Binding Candidates}"
                                     SelectedItem="{Binding SelectedCandidate}"
                                     Padding="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              Margin="0,4">

                                            <!-- Candidate thumbnail -->
                                            <Border Width="76" Height="76"
                                                    CornerRadius="8"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource SurfaceDeepBrush}">
                                                <Image Source="{Binding Subject.ThumbnailPath, Converter={x:Static vm:BitmapAssetValueConverter.Instance}}"
                                                       Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Subject info -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="14,0"
                                                        VerticalAlignment="Center"
                                                        Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Subject.FullName}"
                                                               Classes="h3"/>
                                                    <!-- Method badge -->
                                                    <Border Classes="badge-info"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding MatchMethod}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                                    </Border>
                                                    <!-- Export (visible on selection) -->
                                                    <Button Content="{DynamicResource Str_Match_Export}"
                                                            Command="{Binding #Root.((vm:MatchingViewModel)DataContext).ExportReportCommand}"
                                                            IsVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            Padding="8,3"
                                                            Classes="outline"
                                                            Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='8,0,0,0'}"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{DynamicResource Str_Subj_Col_ID}"
                                                               Classes="caption"/>
                                                    <TextBlock Text="{Binding Subject.SubjectId}"
                                                               Classes="mono caption"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{DynamicResource Str_Subj_Col_NatID}"
                                                               Classes="caption"/>
                                                    <TextBlock Text="{Binding Subject.NationalId}"
                                                               Classes="caption"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Score badge -->
                                            <Border Grid.Column="2"
                                                    Classes="card-compact"
                                                    VerticalAlignment="Center"
                                                    Padding="14,8"
                                                    MinWidth="72">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{DynamicResource Str_Match_Score}"
                                                               Classes="caption"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Score, StringFormat='{}{0:P1}'}"
                                                               FontWeight="Bold"
                                                               FontSize="18"
                                                               Foreground="{DynamicResource SuccessBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border IsVisible="{Binding Candidates.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}"
                                    Background="{DynamicResource OverlayModerateBrush}"
                                    CornerRadius="8"
                                    Margin="2">
                                <TextBlock Text="{DynamicResource Str_Match_NoCandidates}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"/>
                            </Border>

                            <Border IsVisible="{Binding IsMatching}"
                                    Background="{DynamicResource OverlayStrongBrush}"
                                    CornerRadius="8"
                                    Margin="2">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="10"
                                            MinWidth="220">
                                    <TextBlock Text="{DynamicResource Str_Match_Scanning}"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <ProgressBar Value="{Binding MatchingProgress}"
                                                 Maximum="100"
                                                 Height="6"
                                                 Classes="thick"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                </DockPanel>
            </Border>

        </Grid>
    </Grid>

</UserControl>
