<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DentalID.Desktop.ViewModels"
             x:Class="DentalID.Desktop.Views.SubjectsView"
             x:DataType="vm:SubjectsViewModel">

    <!--
    ════════════════════════════════════════════════════
      SUBJECTS VIEW
      Removed all duplicate local styles — global
      AppStyles.axaml covers all control styling.
      Fixed: DangerBrush → ErrorBrush references.
    ════════════════════════════════════════════════════
    -->

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ══════ PAGE HEADER ══════ -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Classes="h1"
                           Text="{DynamicResource Str_Nav_Subjects}"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconSubjects}"
                                  Width="12" Height="12"
                                  Foreground="{DynamicResource AccentPrimaryBrush}"/>
                        <TextBlock Classes="caption">
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=" subjects registered"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Quick-add button -->
            <Button Grid.Column="1"
                    Command="{Binding OpenAddDialogCommand}"
                    Classes="primary"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource IconUser}" Width="14" Height="14"/>
                    <TextBlock Text="{DynamicResource Str_Subj_Add}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ══════ TOOLBAR ══════ -->
        <Border Grid.Row="1"
                Classes="card-compact"
                Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Search -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{Binding SearchQuery}"
                             Watermark="{DynamicResource Str_Subj_SearchPlaceholder}"
                             Width="300" Height="36"
                             Classes="search"/>
                    <Button Command="{Binding SearchCommand}"
                            Classes="ghost"
                            Height="36" Width="36"
                            Padding="8"
                            ToolTip.Tip="Search">
                        <PathIcon Data="{StaticResource IconSearch}"
                                  Width="15" Height="15"/>
                    </Button>
                </StackPanel>

                <!-- Refresh -->
                <Button Grid.Column="1"
                        Content="{DynamicResource Str_Subj_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Classes="ghost"/>
            </Grid>
        </Border>

        <!-- ══════ DATA GRID ══════ -->
        <Border Grid.Row="2"
                Classes="card"
                Padding="0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Subjects}"
                      SelectedItem="{Binding SelectedSubject}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_ID}"
                                        Binding="{Binding SubjectId}"
                                        Width="Auto" MinWidth="120"/>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_Name}"
                                        Binding="{Binding FullName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_Gender}"
                                        Binding="{Binding Gender}"
                                        Width="Auto" MinWidth="80"/>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_DOB}"
                                        Binding="{Binding DateOfBirth, StringFormat='{}{0:yyyy-MM-dd}'}"
                                        Width="Auto" MinWidth="100"/>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_NatID}"
                                        Binding="{Binding NationalId}"
                                        Width="Auto" MinWidth="120"/>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_DentalCode}"
                                        Binding="{Binding LatestDentalCode}"
                                        Width="Auto" MinWidth="150">
                        <DataGridTextColumn.CellTheme>
                            <ControlTheme TargetType="DataGridCell">
                                <Setter Property="FontFamily" Value="{DynamicResource FontMono}"/>
                            </ControlTheme>
                        </DataGridTextColumn.CellTheme>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{DynamicResource Str_Subj_Col_Created}"
                                        Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                        Width="Auto" MinWidth="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ══════ PAGINATION & ROW ACTIONS ══════ -->
        <Border Grid.Row="3"
                Classes="card-compact"
                Margin="0,12,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Row actions (enabled only when row selected) -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource Str_Subj_Edit}"
                            Command="{Binding OpenEditDialogCommand}"
                            Classes="outline"
                            Padding="14,7"
                            IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <Button Content="{DynamicResource Str_Subj_Delete}"
                            Command="{Binding DeleteSubjectCommand}"
                            Classes="danger"
                            Padding="14,7"
                            IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </StackPanel>

                <!-- Pagination controls -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0">
                        <Run Text="{DynamicResource Str_Subj_Total}"/>
                        <Run Text="{Binding TotalCount}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <Button Command="{Binding PreviousPageCommand}"
                            Classes="ghost"
                            Width="32" Height="32"
                            Padding="6"
                            IsEnabled="{Binding HasPreviousPage}">
                        <PathIcon Data="{StaticResource IconArrowLeft}" Width="12" Height="12"/>
                    </Button>

                    <TextBlock Text="{Binding PageInfo}"
                               FontSize="13"
                               VerticalAlignment="Center"/>

                    <Button Command="{Binding NextPageCommand}"
                            Classes="ghost"
                            Width="32" Height="32"
                            Padding="6"
                            IsEnabled="{Binding HasNextPage}">
                        <PathIcon Data="{StaticResource IconArrowRight}" Width="12" Height="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ ADD / EDIT DIALOG OVERLAY ══════ -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                IsVisible="{Binding IsAddEditDialogOpen}"
                Background="#88000000">
            <Border Classes="card"
                    Width="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">

                    <!-- Dialog header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="h2"
                                   Text="{Binding IsEditing, Converter={x:Static vm:EditTitleConverter.Instance}}"/>
                        <Button Grid.Column="1"
                                Command="{Binding CloseDialogCommand}"
                                Classes="ghost icon"
                                Padding="6">
                            <PathIcon Data="{StaticResource IconArrowRight}" Width="14" Height="14"
                                      Foreground="{DynamicResource TextMutedBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                    <!-- Full Name -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="label"
                                   Text="{DynamicResource Str_Subj_Dialog_Name}"/>
                        <TextBox Text="{Binding FormFullName}"
                                 Watermark="{DynamicResource Str_Subj_Dialog_NamePlace}"/>
                    </StackPanel>

                    <!-- Gender -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="label"
                                   Text="{DynamicResource Str_Subj_Dialog_Gender}"/>
                        <ComboBox SelectedItem="{Binding FormGender}" Width="200">
                            <ComboBoxItem Content="{DynamicResource Str_Subj_Dialog_Male}"/>
                            <ComboBoxItem Content="{DynamicResource Str_Subj_Dialog_Female}"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Date of Birth -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="label"
                                   Text="{DynamicResource Str_Subj_Dialog_DOB}"/>
                        <DatePicker SelectedDate="{Binding FormDateOfBirth}"/>
                    </StackPanel>

                    <!-- National ID -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="label"
                                   Text="{DynamicResource Str_Subj_Dialog_NatID}"/>
                        <TextBox Text="{Binding FormNationalId}"
                                 Watermark="{DynamicResource Str_Subj_Dialog_Optional}"/>
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="label"
                                   Text="{DynamicResource Str_Subj_Dialog_Notes}"/>
                        <TextBox Text="{Binding FormNotes}"
                                 Watermark="{DynamicResource Str_Subj_Dialog_NotesPlace}"
                                 AcceptsReturn="True"
                                 Height="70"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                    <!-- Dialog actions -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right">
                        <Button Content="{DynamicResource Str_Cancel}"
                                Command="{Binding CloseDialogCommand}"
                                Classes="ghost"
                                Padding="16,9"/>
                        <Button Content="{DynamicResource Str_Save}"
                                Command="{Binding SaveSubjectCommand}"
                                Classes="primary"
                                Padding="20,9"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
