<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DentalID.Desktop.ViewModels"
             xmlns:svc="using:DentalID.Desktop.Services"
             xmlns:conv="using:DentalID.Desktop.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="DentalID.Desktop.Views.MainView"
             x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="Auto, *, Auto" Background="#101216">
        <!-- Ambient background layers -->
        <Canvas IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="560" Height="560" Canvas.Left="-180" Canvas.Top="-220" Opacity="0.18">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="70%" RadiusY="70%">
                        <GradientStop Offset="0.0" Color="#5A0078D4"/>
                        <GradientStop Offset="1.0" Color="#000078D4"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="520" Height="520" Canvas.Right="-220" Canvas.Bottom="-220" Opacity="0.12">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="70%" RadiusY="70%">
                        <GradientStop Offset="0.0" Color="#4A60CDFF"/>
                        <GradientStop Offset="1.0" Color="#0060CDFF"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <!-- TOP COMMAND BAR (Floating Style) -->
        <Border Grid.Row="0"
                Margin="14,12,14,8"
                Height="54"
                Background="#CC1B2028"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Branding -->
                <StackPanel Orientation="Horizontal"
                             Margin="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='20,0,0,0'}"
                             VerticalAlignment="Center"
                             Spacing="12">
                     <TextBlock Text="DENTAL ID" FontWeight="Bold" FontSize="16" LetterSpacing="2" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{DynamicResource FontSans}"/>
                     <Border Height="16" Width="1" Background="{DynamicResource BorderSubtleBrush}"/>
                     <TextBlock Text="FORENSIC SUITE" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" FontFamily="{DynamicResource FontSans}"/>
                </StackPanel>

                <!-- Breadcrumbs / Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Background="#18FFFFFF" CornerRadius="6" Padding="12,5" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                              <PathIcon Data="{StaticResource IconFingerprint}" Width="14" Height="14" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                            <TextBlock Text="DENTAL ID" Classes="mono" Foreground="{DynamicResource TextDisabledBrush}" FontSize="12"/>
                            <PathIcon Data="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToArrowGeometryConverter.Instance}, ConverterParameter=Next}" Width="10" Height="10" Foreground="{DynamicResource TextDisabledBrush}"/>
                            <TextBlock Text="{Binding CurrentPageTitle}" FontWeight="SemiBold" Foreground="{DynamicResource AccentSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Window Controls & Profile -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Margin="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,20,0'}"
                            Spacing="16"
                            VerticalAlignment="Center">
                    <Button Classes="ghost" ToolTip.Tip="{DynamicResource Str_GlobalSearch}" Padding="8">
                        <PathIcon Data="{StaticResource IconSearch}" Width="16" Height="16"/>
                    </Button>
                    <Button Classes="ghost" ToolTip.Tip="{DynamicResource Str_Notifications}" Padding="8">
                        <PathIcon Data="{StaticResource IconBell}" Width="16" Height="16"/>
                    </Button>
                    
                    <Border Width="1" Height="20" Background="{DynamicResource BorderSubtleBrush}"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource SurfaceElevatedBrush}" ClipToBounds="True" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                             <PathIcon Data="{StaticResource IconUser}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUserName}" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1" ColumnDefinitions="92, *" Margin="14,0,14,10">
             
            <!-- SIDEBAR (Navigation Rail - Left) -->
            <Border Grid.Column="0"
                    Margin="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,12,0'}"
                    CornerRadius="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredCornerRadiusConverter.Instance}, ConverterParameter='0,12,12,0'}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,1,1,1'}"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F012161D" Offset="0"/>
                        <GradientStop Color="#F00B0E13" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto, *, Auto">
                    
                    <!-- Branding Mark (Top) -->
                    <Border Height="60" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Image Source="/Assets/Brand/dental.png"
                               Width="30"
                               Height="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Navigation Items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel Spacing="16" Margin="0,20">
                            
                            <ListBox x:Name="NavListBox" SelectedIndex="{Binding SelectedNavIndex, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Width" Value="48"/>
                                        <Setter Property="Height" Value="48"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#15FFFFFF"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                        <Setter Property="BoxShadow" Value="0 8 18 0 #320078D4"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected PathIcon">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pressed /template/ ContentPresenter">
                                         <Setter Property="RenderTransform" Value="scale(0.90)"/>
                                    </Style>
                                </ListBox.Styles>

                                <ListBoxItem ToolTip.Tip="{DynamicResource Str_Nav_Subjects}">
                                    <Button Command="{Binding NavigateToSubjectsCommand}" Classes="nav-button" Padding="0">
                                        <PathIcon Data="{StaticResource IconSubjects}" Width="20" Height="20" HorizontalAlignment="Center"/>
                                    </Button>
                                </ListBoxItem>
                                <ListBoxItem ToolTip.Tip="{DynamicResource Str_Nav_Analysis}">
                                    <Button Command="{Binding NavigateToAnalysisLabCommand}" Classes="nav-button" Padding="0">
                                        <PathIcon Data="{StaticResource IconAnalysis}" Width="20" Height="20" HorizontalAlignment="Center"/>
                                    </Button>
                                </ListBoxItem>
                                <ListBoxItem ToolTip.Tip="{DynamicResource Str_Nav_Matching}">
                                    <Button Command="{Binding NavigateToMatchingCommand}" Classes="nav-button" Padding="0">
                                        <PathIcon Data="{StaticResource IconMatching}" Width="20" Height="20" HorizontalAlignment="Center"/>
                                    </Button>
                                </ListBoxItem>
                            </ListBox>

                            <Border Height="1" Width="30" Background="{DynamicResource BorderSubtleBrush}" Opacity="0.3"/>
                            
                            <!-- Settings Logic (Separate ListBox for better control) -->
                             <ListBox SelectedIndex="{Binding SettingsNavIndex}" Background="Transparent" BorderThickness="0">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Width" Value="48"/>
                                        <Setter Property="Height" Value="48"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                     <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#15FFFFFF"/>
                                    </Style>
                                </ListBox.Styles>
                                 <ListBoxItem ToolTip.Tip="{DynamicResource Str_Nav_Settings}">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="20" Height="20" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </ListBoxItem>
                            </ListBox>

                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Sidebar Footer (System Status) -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,20" HorizontalAlignment="Center">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource SuccessBrush}" ToolTip.Tip="{DynamicResource Str_SystemOnline}">
                            <Border.Effect>
                                <BlurEffect Radius="4"/>
                            </Border.Effect>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT AREA (Right) -->
            <Grid Grid.Column="1">
                <Border Background="{DynamicResource PageBgBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        ClipToBounds="True">
                     <Grid>
                        <!-- Digital Grid Pattern -->
                        <Grid Opacity="0.02" IsVisible="{Binding IsFocusMode, Converter={x:Static BoolConverters.Not}}">
                            <Path Data="M0,0 L20,20 M20,0 L0,20" Stroke="{DynamicResource AccentPrimaryBrush}" StrokeThickness="1" Stretch="Fill"/>
                         </Grid>
                         
                         <!-- Main Content -->
                         <ContentControl Content="{Binding CurrentView}" Margin="8"/>
                     </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Margin="14,0,14,10"
                Height="34"
                Background="#C9151A20"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid ColumnDefinitions="Auto, *, Auto" Margin="16,0">
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconCheckCircle}" Width="12" Height="12" Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="{DynamicResource Str_Status_SecureConnection}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                     <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{DynamicResource Str_Status_AiEngine}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextDisabledBrush}"/>
                        <TextBlock Text="{DynamicResource Str_Status_AiRuntime}" FontSize="10" Foreground="{DynamicResource AccentTertiaryBrush}"/>
                     </StackPanel>
                     <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{DynamicResource Str_Status_Label}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextDisabledBrush}"/>
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsBusy}"
                                     Width="60"
                                     Height="2"
                                     VerticalAlignment="Center"
                                     Margin="{Binding [IsRtl], Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,8,0'}"
                                     Foreground="{DynamicResource AccentPrimaryBrush}"/>
                        <TextBlock Text="{Binding BusyMessage}" FontSize="10" Foreground="{DynamicResource SuccessBrush}"/>
                     </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
