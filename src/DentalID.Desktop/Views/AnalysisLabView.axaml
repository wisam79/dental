<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DentalID.Desktop.ViewModels"
             xmlns:svc="using:DentalID.Desktop.Services"
             xmlns:conv="using:DentalID.Desktop.Converters"
             xmlns:local="using:DentalID.Desktop.Views"
             xmlns:controls="using:DentalID.Desktop.Controls"
             xmlns:viewcontrols="using:DentalID.Desktop.Views.Controls"
             x:Class="DentalID.Desktop.Views.AnalysisLabView"
             xmlns:core="using:DentalID.Core.Entities"
             x:DataType="vm:AnalysisLabViewModel">

    <UserControl.Styles>
        <!-- Custom Styles specific to Lab -->
        <Style Selector="TabControl.report-tabs TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Padding" Value="6,10"/>
        </Style>
        <Style Selector="TabControl.report-tabs TabItem:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TabControl.report-tabs TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TabControl.report-tabs TabItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="TabControl.report-tabs TabItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource OverlaySubtleBrush}"/>
        </Style>
        <Style Selector="TabControl.report-tabs TabItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource OverlayHoverBrush}"/>
        </Style>

        <Style Selector="Border.report-section">
            <Setter Property="Background" Value="{DynamicResource SurfaceFloatingBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.metric-tile">
            <Setter Property="Background" Value="#12000000"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style Selector="TextBlock.metric-value">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LineHeight" Value="36"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.metric-label">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="LineHeight" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.metric-status">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LineHeight" Value="28"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.lab-tool">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.lab-tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource OverlayHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
        </Style>

        <Style Selector="ToggleButton.lab-tool">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.lab-tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource OverlayHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *" Background="{DynamicResource SurfaceDeepBrush}">

        <!-- ═══════════════════════════════════════════ -->
        <!-- 1. TOP BAR: CONTEXT & PRIMARY ACTIONS -->
        <Border Grid.Row="0" Height="58" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="16,4">
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <!-- Left: Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource IconAnalysis}" Foreground="{DynamicResource AccentPrimaryBrush}" Width="16" Height="16"/>
                    <TextBlock Text="{Binding [Lab_Title], Source={x:Static svc:Loc.Instance}}" Classes="h2" FontSize="14" VerticalAlignment="Center" LetterSpacing="1"/>
                </StackPanel>

                <!-- Center: Search (Simplified) -->
                <Grid Grid.Column="1" Margin="32,10" MaxWidth="640">
                    <Border CornerRadius="6" Background="{DynamicResource SurfaceFloatingBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                        <Grid ColumnDefinitions="Auto, *">
                            <PathIcon Data="{StaticResource IconSearch}" Margin="10,0" Width="14" Height="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <AutoCompleteBox Grid.Column="1" 
                                           ItemsSource="{Binding Subjects}"
                                           SelectedItem="{Binding SelectedSubject}"
                                           Text="{Binding SearchQuery}"
                                           Watermark="{Binding [Lab_SearchPlaceholder], Source={x:Static svc:Loc.Instance}}"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Right: Analysis Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border IsVisible="{Binding IsIdle, Converter={x:Static BoolConverters.Not}}"
                            Background="{DynamicResource OverlayHoverBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,5"
                            MaxWidth="200">
                        <TextBlock Text="{Binding StatusMessage, FallbackValue=Ready}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Button Command="{Binding BrowseImageCommand}" Classes="outline" CornerRadius="4" Padding="12,6" IsEnabled="{Binding !IsAnalyzing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource IconFolderOpen}" Width="14" Height="14"/>
                            <TextBlock Text="{Binding [Lab_BrowseImage], Source={x:Static svc:Loc.Instance}}" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RunAnalysisCommand}" Classes="primary" CornerRadius="4" Padding="16,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource IconAnalysis}" Width="14" Height="14" IsVisible="{Binding !IsAnalyzing}"/>
                            <PathIcon Data="{StaticResource IconRefresh}" Width="14" Height="14" IsVisible="{Binding IsAnalyzing}" RenderTransformOrigin="50%,50%">
                                <PathIcon.RenderTransform>
                                    <RotateTransform Angle="{Binding AnalysisSpinnerAngle}"/>
                                </PathIcon.RenderTransform>
                            </PathIcon>
                            <TextBlock Text="{Binding [Lab_RunAnalysis], Source={x:Static svc:Loc.Instance}}" FontSize="11" FontWeight="Bold" IsVisible="{Binding !IsAnalyzing}"/>
                            <TextBlock Text="{Binding [Lab_Analyzing], Source={x:Static svc:Loc.Instance}}" FontSize="11" FontWeight="Bold" IsVisible="{Binding IsAnalyzing}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1" ColumnSpacing="10" Margin="8,6,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" MinWidth="320" MaxWidth="500"/>
            </Grid.ColumnDefinitions>
            
             <!-- 2. LEFT STRIP: TOOLS (Floating Palette Style) -->
             <Grid Grid.Column="0" Width="64" Background="Transparent">
                 <Border Background="{DynamicResource SurfaceElevatedBrush}" Margin="0,16,0,16" CornerRadius="10" VerticalAlignment="Stretch" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                     <StackPanel Spacing="4" Margin="0,8">
                         <Button Classes="lab-tool" ToolTip.Tip="{Binding [Lab_Enhance_Reset], Source={x:Static svc:Loc.Instance}}" Click="OnResetZoom">
                             <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                         </Button>
                         
                         <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="8,4" Opacity="0.5"/>
                         
                         <ToggleButton IsChecked="{Binding ShowTeethOverlay}" Classes="lab-tool" ToolTip.Tip="{Binding [Lab_Stats_Teeth], Source={x:Static svc:Loc.Instance}}">
                             <PathIcon Data="{StaticResource IconTooth}" Width="20" Height="20"/>
                             <ToggleButton.Styles>
                                <Style Selector="ToggleButton:checked">
                                    <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                     <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </ToggleButton.Styles>
                         </ToggleButton>
                         
                         <ToggleButton IsChecked="{Binding ShowPathosOverlay}" Classes="lab-tool" ToolTip.Tip="{Binding [Lab_DetectedPathologies], Source={x:Static svc:Loc.Instance}}">
                             <PathIcon Data="{StaticResource IconWarning}" Width="20" Height="20"/>
                              <ToggleButton.Styles>
                                <Style Selector="ToggleButton:checked">
                                    <Setter Property="Background" Value="#D83B01"/>
                                     <Setter Property="Foreground" Value="White"/>
                                </Style>
                            </ToggleButton.Styles>
                         </ToggleButton>
                         
                         <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="8,4" Opacity="0.5"/>
                         
                         <!-- Advanced Tools -->
                          <Button Classes="lab-tool" ToolTip.Tip="{Binding [Lab_Enhance_Title], Source={x:Static svc:Loc.Instance}}">
                             <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                             <Button.Flyout>
                                 <Flyout Placement="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToFlyoutPlacementConverter.Instance}, ConverterParameter=End}" ShowMode="TransientWithDismissOnPointerMoveAway">
                                     <Border Classes="card" Padding="16" Width="220">
                                         <StackPanel Spacing="12">
                                             <TextBlock Text="{Binding [Lab_Enhance_Title], Source={x:Static svc:Loc.Instance}}" Classes="label" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                             
                                             <StackPanel Spacing="4">
                                                 <DockPanel>
                                                     <PathIcon Data="{StaticResource IconSun}" Width="12" Height="12" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,8,0'}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                     <TextBlock Text="{Binding [Lab_Enhance_Bright], Source={x:Static svc:Loc.Instance}}" FontSize="11"/>
                                                     <TextBlock Text="{Binding WindowCenter, StringFormat='{}{0:F2}'}" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=End}" FlowDirection="LeftToRight" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                 </DockPanel>
                                                 <Slider Value="{Binding WindowCenter}" Minimum="0" Maximum="1" Classes="modern"/>
                                             </StackPanel>
                                             
                                             <StackPanel Spacing="4">
                                                 <DockPanel>
                                                     <PathIcon Data="{StaticResource IconEye}" Width="12" Height="12" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,8,0'}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                     <TextBlock Text="{Binding [Lab_Enhance_Contrast], Source={x:Static svc:Loc.Instance}}" FontSize="11"/>
                                                     <TextBlock Text="{Binding WindowWidth, StringFormat='{}{0:F2}'}" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=End}" FlowDirection="LeftToRight" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                 </DockPanel>
                                                 <Slider Value="{Binding WindowWidth}" Minimum="0.5" Maximum="2" Classes="modern"/>
                                             </StackPanel>
                                             
                                             <Button Content="{Binding [Lab_Enhance_Reset], Source={x:Static svc:Loc.Instance}}" Classes="outline" HorizontalAlignment="Stretch" FontSize="11"/>
                                         </StackPanel>
                                     </Border>
                                 </Flyout>
                             </Button.Flyout>
                         </Button>
                     </StackPanel>
                 </Border>
             </Grid>

             <!-- 3. CENTER: IMMERSIVE CANVAS -->
             <Grid Grid.Column="1" Background="#050505" ClipToBounds="True" Margin="0,16,0,16">
                 <!-- Technical Background Grid -->
                 <Grid Opacity="0.1">
                    <Path Data="M0,0 L40,40 M40,0 L0,40" Stroke="{DynamicResource BorderSubtleBrush}" StrokeThickness="1" Stretch="None" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=Start}" VerticalAlignment="Top">
                         <Path.RenderTransform>
                            <ScaleTransform ScaleX="20" ScaleY="20"/>
                        </Path.RenderTransform>
                    </Path>
                 </Grid>
                 
                  <!-- Empty State (Idle) -->
                  <Border IsVisible="{Binding IsIdle}" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="2" CornerRadius="16" Padding="60,40" Opacity="0.8">
                      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                          <Border Width="90" Height="90" CornerRadius="45" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                              <PathIcon Data="{StaticResource IconFolderOpen}" Width="36" Height="36" Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <StackPanel HorizontalAlignment="Center" Spacing="8">
                              <TextBlock Text="{Binding [Lab_DropZone], Source={x:Static svc:Loc.Instance}}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                              <TextBlock Text="{Binding [Lab_UploadHint], Source={x:Static svc:Loc.Instance}}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"/>
                          </StackPanel>
                          <Button Command="{Binding BrowseImageCommand}" Classes="primary" Padding="32,12" CornerRadius="8" HorizontalAlignment="Center">
                              <StackPanel Orientation="Horizontal" Spacing="10">
                                  <PathIcon Data="{StaticResource IconFolderOpen}" Width="16" Height="16"/>
                                  <TextBlock Text="{Binding [Lab_BrowseImage], Source={x:Static svc:Loc.Instance}}" FontSize="14" FontWeight="Bold"/>
                              </StackPanel>
                          </Button>
                      </StackPanel>
                  </Border>

                   <!-- Viewer -->
                   <viewcontrols:AdvancedImageViewer x:Name="AdvancedViewer" IsVisible="{Binding IsImageLoaded}">
                       <viewcontrols:AdvancedImageViewer.InnerContent>
                           <controls:DentalAnalysisControl Name="AnalysisControl"
                               Source="{Binding LoadedImagePath, Converter={x:Static vm:BitmapAssetValueConverter.Instance}}"
                               Teeth="{Binding DetectedTeeth}"
                               Pathologies="{Binding DetectedPathologies}"
                               ShowTeeth="{Binding ShowTeethOverlay}"
                               ShowPathologies="{Binding ShowPathosOverlay}"
                               LocalizationService="{Binding LocalizationService}" />
                       </viewcontrols:AdvancedImageViewer.InnerContent>
                   </viewcontrols:AdvancedImageViewer>
                  
                  <!-- Overlay Info (Metadata) -->
                  <Border VerticalAlignment="Top" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=Start}" Margin="20" Background="#90000000" CornerRadius="4" Padding="12,8" IsVisible="{Binding IsImageLoaded}" BorderBrush="#30FFFFFF" BorderThickness="1">
                      <StackPanel Spacing="4">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                              <PathIcon Data="{StaticResource IconFile}" Width="12" Height="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                              <TextBlock Text="{Binding ImageFileName}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                          </StackPanel>
                          <TextBlock Text="{Binding [Lab_ImageInfo], Source={x:Static svc:Loc.Instance}}" FontSize="10" Foreground="{DynamicResource TextDisabledBrush}" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='20,0,0,0'}"/>
                      </StackPanel>
                  </Border>

                  <!-- Loading Overlay -->
                  <Border IsVisible="{Binding IsLoadingImage}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000">
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                           <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="32" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                               <StackPanel Spacing="16" HorizontalAlignment="Center">
                                   <Border Classes="shimmer" Width="200" Height="4" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                   <StackPanel HorizontalAlignment="Center" Spacing="4">
                                       <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                   </StackPanel>
                               </StackPanel>
                           </Border>
                      </StackPanel>
                  </Border>

                  <!-- Analysis Progress Overlay (Glass) -->
                  <Border IsVisible="{Binding IsAnalyzing}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000">
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                          <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="32" BorderBrush="{DynamicResource AccentPrimaryBrush}" BorderThickness="1">
                              <StackPanel Spacing="16" HorizontalAlignment="Center" MinWidth="320">
                                  <Border Classes="pulse-accent" Width="64" Height="64" CornerRadius="32" BorderBrush="{DynamicResource AccentPrimaryBrush}" BorderThickness="1" Background="#132F84AE">
                                      <PathIcon Data="{StaticResource IconRefresh}" Width="28" Height="28" Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="50%,50%">
                                          <PathIcon.RenderTransform>
                                              <RotateTransform Angle="{Binding AnalysisSpinnerAngle}"/>
                                          </PathIcon.RenderTransform>
                                      </PathIcon>
                                  </Border>
                                  <StackPanel HorizontalAlignment="Center" Spacing="4">
                                      <TextBlock Text="{Binding [Lab_Analyzing], Source={x:Static svc:Loc.Instance}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                      <TextBlock Text="{Binding AnalysisPhase}" Foreground="{DynamicResource AccentSecondaryBrush}" FontSize="12" HorizontalAlignment="Center"/>
                                  </StackPanel>
                                  <StackPanel Spacing="6" Width="280">
                                      <ProgressBar Value="{Binding AnalysisVisualProgress}" Minimum="0" Maximum="100" Height="5" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                      <Grid ColumnDefinitions="*,Auto">
                                          <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                          <TextBlock Grid.Column="1" Text="{Binding AnalysisVisualProgress, StringFormat='{}{0:0}%'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                      </Grid>
                                      <Border CornerRadius="8" Padding="8,4" Background="#16000000" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                          <TextBlock HorizontalAlignment="Center" FontFamily="{DynamicResource FontMono}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                              <Run Text="{Binding [Lab_Elapsed], Source={x:Static svc:Loc.Instance}}"/>
                                              <Run Text=": "/>
                                              <Run Text="{Binding AnalysisElapsed}"/>
                                          </TextBlock>
                                      </Border>
                                  </StackPanel>
                              </StackPanel>
                          </Border>
                      </StackPanel>
                  </Border>

                  <!-- Error State Overlay -->
                  <Border IsVisible="{Binding IsError}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000">
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                          <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="32" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1">
                              <StackPanel Spacing="16" HorizontalAlignment="Center">
                                  <Border Width="56" Height="56" CornerRadius="28" Background="#20FF4444">
                                      <PathIcon Data="{StaticResource IconWarning}" Width="28" Height="28" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                  </Border>
                                  <StackPanel HorizontalAlignment="Center" Spacing="8">
                                      <TextBlock Text="Analysis Failed" Foreground="{DynamicResource ErrorBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                      <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" MaxWidth="300" HorizontalAlignment="Center" TextAlignment="Center"/>
                                  </StackPanel>
                                  <Button Command="{Binding RunAnalysisCommand}" Classes="outline" HorizontalAlignment="Center" Padding="24,8">
                                      <StackPanel Orientation="Horizontal" Spacing="8">
                                          <PathIcon Data="{StaticResource IconRefresh}" Width="14" Height="14"/>
                                          <TextBlock Text="Retry" FontWeight="SemiBold"/>
                                      </StackPanel>
                                  </Button>
                              </StackPanel>
                          </Border>
                      </StackPanel>
                  </Border>

                  <!-- Saving State Overlay -->
                  <Border IsVisible="{Binding IsSaving}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000">
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                          <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="32" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1">
                               <StackPanel Spacing="16" HorizontalAlignment="Center">
                                   <Border Classes="shimmer" Width="200" Height="4" Margin="0,0,0,8"/>
                                   <StackPanel HorizontalAlignment="Center" Spacing="4">
                                       <TextBlock Text="Saving Evidence..." Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                       <TextBlock Text="Encrypting and storing to database" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center"/>
                                   </StackPanel>
                               </StackPanel>
                          </Border>
                      </StackPanel>
                  </Border>
             </Grid>

             <!-- 4. RIGHT PANEL: RESULTS & REPORT -->
             <Border Grid.Column="2"
                     Margin="0,16,0,16"
                     CornerRadius="12"
                     ClipToBounds="True"
                     Background="{DynamicResource SurfaceElevatedBrush}"
                     BorderBrush="{DynamicResource BorderSubtleBrush}"
                     BorderThickness="1">
                 <Grid RowDefinitions="Auto,*,Auto">
                     <Border Grid.Row="0"
                             Padding="16,14"
                             Background="{DynamicResource SurfaceFloatingBrush}"
                             BorderBrush="{DynamicResource BorderSubtleBrush}"
                             BorderThickness="0,0,0,1">
                         <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                             <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                 <PathIcon Data="{StaticResource IconAnalysis}"
                                           Width="16"
                                           Height="16"
                                           Foreground="{DynamicResource AccentSecondaryBrush}"/>
                                 <TextBlock Text="{Binding [Lab_Report_Title], Source={x:Static svc:Loc.Instance}}"
                                            Classes="h3"
                                            FontSize="18"
                                            FontWeight="Bold"/>
                             </StackPanel>
                             <Button Grid.Column="1" Classes="ghost" Padding="6">
                                 <PathIcon Data="{StaticResource IconDotsHorizontal}" Width="16" Height="16"/>
                             </Button>
                         </Grid>
                     </Border>
                     
                      <TabControl Grid.Row="1" Margin="0" Padding="0" Classes="report-tabs">
                         <TabItem Header="{Binding [Lab_Tab_Summary], Source={x:Static svc:Loc.Instance}}" FontSize="12">
                              <ScrollViewer Padding="14" VerticalScrollBarVisibility="Auto">
                                 <StackPanel Spacing="14">
                                     <!-- Bio Profile Card -->
                                     <Border Classes="card report-section" Padding="0">
                                         <StackPanel>
                                             <Border Background="{DynamicResource SurfaceBgBrush}" Padding="12,9" CornerRadius="10 10 0 0" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                                                 <DockPanel>
                                                     <PathIcon Data="{StaticResource IconUser}" Width="12" Height="12" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,8,0'}" Foreground="{DynamicResource AccentSecondaryBrush}"/>
                                                     <TextBlock Text="{Binding [Lab_Bio_Profile], Source={x:Static svc:Loc.Instance}}" Classes="label" FontWeight="Bold" FontSize="12"/>
                                                 </DockPanel>
                                             </Border>
                                             <Grid ColumnDefinitions="*,10,*" Margin="12">
                                                 <Border Grid.Column="0" Classes="metric-tile">
                                                     <StackPanel Spacing="2">
                                                         <TextBlock IsVisible="{Binding IsAnalysisComplete}" Text="{Binding EstimatedAge, FallbackValue='--'}" Classes="metric-value"/>
                                                         <viewcontrols:SkeletonLoader IsVisible="{Binding IsAnalysisComplete, Converter={x:Static BoolConverters.Not}}" Height="28" Width="40" HorizontalAlignment="Left" CornerRadius="4"/>
                                                         <TextBlock Text="{Binding [Lab_EstAge], Source={x:Static svc:Loc.Instance}}" Classes="metric-label"/>
                                                     </StackPanel>
                                                 </Border>
                                                 <Border Grid.Column="2" Classes="metric-tile">
                                                     <StackPanel Spacing="2">
                                                         <TextBlock IsVisible="{Binding IsAnalysisComplete}" Text="{Binding EstimatedGender, FallbackValue='--'}"
                                                                    Classes="metric-value"
                                                                    FontSize="26"
                                                                    LineHeight="32"
                                                                    MaxWidth="140"
                                                                    TextWrapping="Wrap"/>
                                                         <viewcontrols:SkeletonLoader IsVisible="{Binding IsAnalysisComplete, Converter={x:Static BoolConverters.Not}}" Height="28" Width="70" HorizontalAlignment="Left" CornerRadius="4" Margin="0,2,0,2"/>
                                                         <TextBlock Text="{Binding [Lab_Gender], Source={x:Static svc:Loc.Instance}}" Classes="metric-label"/>
                                                     </StackPanel>
                                                 </Border>
                                             </Grid>
                                         </StackPanel>
                                     </Border>
                                     
                                      <!-- Stats -->
                                     <Grid ColumnDefinitions="*,10,*">
                                         <Border Grid.Column="0" Classes="card report-section" Padding="12" MinHeight="108">
                                             <StackPanel Spacing="4" VerticalAlignment="Center">
                                                 <PathIcon Data="{StaticResource IconTooth}" Width="16" Height="16" Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=Start}"/>
                                                 <TextBlock IsVisible="{Binding IsAnalysisComplete}" Text="{Binding TeethDetectedCount}" Classes="metric-value" FontSize="36" LineHeight="40" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                 <viewcontrols:SkeletonLoader IsVisible="{Binding IsAnalysisComplete, Converter={x:Static BoolConverters.Not}}" Height="40" Width="40" HorizontalAlignment="Left" CornerRadius="4"/>
                                                 <TextBlock Text="{Binding [Lab_Stats_Teeth], Source={x:Static svc:Loc.Instance}}" Classes="metric-label" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=Start}" TextAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalTextAlignmentConverter.Instance}, ConverterParameter=Start}"/>
                                             </StackPanel>
                                         </Border>
                                         <Border Grid.Column="2" Classes="card report-section" Padding="12" MinHeight="108">
                                             <StackPanel Spacing="4" VerticalAlignment="Center">
                                                 <PathIcon Data="{StaticResource IconWarning}" Width="16" Height="16" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=Start}"/>
                                                 <TextBlock IsVisible="{Binding IsAnalysisComplete}" Text="{Binding PathologiesCount}" Classes="metric-value" FontSize="36" LineHeight="40" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                 <viewcontrols:SkeletonLoader IsVisible="{Binding IsAnalysisComplete, Converter={x:Static BoolConverters.Not}}" Height="40" Width="40" HorizontalAlignment="Left" CornerRadius="4"/>
                                                 <TextBlock Text="{Binding [Lab_Stats_Flags], Source={x:Static svc:Loc.Instance}}" Classes="metric-label" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=Start}" TextAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalTextAlignmentConverter.Instance}, ConverterParameter=Start}"/>
                                             </StackPanel>
                                         </Border>
                                     </Grid>
 
                                     <!-- Digital Fingerprint Card -->
                                     <Border Classes="card report-section" Padding="0" IsVisible="{Binding IsAnalysisComplete}">
                                         <StackPanel>
                                             <Border Background="#162F84AE" Padding="12,9" CornerRadius="10 10 0 0" BorderBrush="#402F84AE" BorderThickness="0,0,0,1">
                                                 <DockPanel>
                                                     <PathIcon Data="{StaticResource IconFingerprint}" Width="14" Height="14" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,8,0'}" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                                     <TextBlock Text="{Binding [Lab_Fingerprint_Title], Source={x:Static svc:Loc.Instance}}" Classes="label" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}" FontSize="12"/>
                                                     <Border Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="10" Padding="6,2" HorizontalAlignment="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToLogicalHorizontalAlignmentConverter.Instance}, ConverterParameter=End}" VerticalAlignment="Center">
                                                         <TextBlock Text="ID" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                     </Border>
                                                 </DockPanel>
                                             </Border>
                                             <StackPanel Margin="12" Spacing="10">
                                                 <!-- Dental Code -->
                                                 <StackPanel Spacing="4">
                                                     <TextBlock Text="{Binding [Lab_Fingerprint_Code], Source={x:Static svc:Loc.Instance}}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                                     <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="8,6" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                                         <ScrollViewer MaxHeight="70" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                             <TextBlock Text="{Binding FingerprintCode, FallbackValue='--'}" 
                                                                        FontFamily="{DynamicResource FontMono}"
                                                                        FontSize="11"
                                                                        FlowDirection="LeftToRight"
                                                                        TextWrapping="Wrap"
                                                                        LineHeight="18"
                                                                        Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                         </ScrollViewer>
                                                     </Border>
                                                 </StackPanel>
                                                 <!-- Uniqueness + Vector Status -->
                                                 <Grid ColumnDefinitions="*,1,*">
                                                     <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="2">
                                                         <TextBlock Text="{Binding UniquenessScore, StringFormat='{}{0:F1}', FallbackValue='0'}"
                                                                    Classes="metric-value"
                                                                    FontSize="34"
                                                                    LineHeight="38"
                                                                    Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                                         <TextBlock Text="{Binding [Lab_Fingerprint_Uniqueness], Source={x:Static svc:Loc.Instance}}" Classes="metric-label"/>
                                                     </StackPanel>
                                                     <Border Grid.Column="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,4"/>
                                                     <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="2">
                                                         <TextBlock Text="✓" Classes="metric-status"
                                                                    IsVisible="{Binding HasFeatureVector}" Foreground="{DynamicResource AccentGreenBrush}"/>
                                                         <TextBlock Text="✗" Classes="metric-status"
                                                                    IsVisible="{Binding !HasFeatureVector}" Foreground="{DynamicResource ErrorBrush}"/>
                                                         <TextBlock Text="{Binding [Lab_Fingerprint_Vector], Source={x:Static svc:Loc.Instance}}" Classes="metric-label"/>
                                                     </StackPanel>
                                                 </Grid>
                                             </StackPanel>
                                         </StackPanel>
                                     </Border>

                                     <!-- AI Insights List -->
                                     <StackPanel Spacing="10">
                                         <DockPanel>
                                             <TextBlock Text="{Binding [Lab_AI_Findings], Source={x:Static svc:Loc.Instance}}" Classes="label" FontWeight="Bold" VerticalAlignment="Center"/>
                                             <Border Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="10" Padding="6,2" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='8,0,0,0'}" VerticalAlignment="Center">
                                                 <TextBlock Text="AI" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                             </Border>
                                         </DockPanel>
                                         
                                         <ItemsControl ItemsSource="{Binding SmartInsights}">
                                             <ItemsControl.ItemTemplate>
                                                 <DataTemplate>
                                                     <Border Margin="0,4" Padding="12" Background="{DynamicResource SurfaceFloatingBrush}" CornerRadius="6" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                                          <Grid ColumnDefinitions="24, *">
                                                              <PathIcon Data="{StaticResource IconInfo}" Width="14" Height="14" Foreground="{DynamicResource AccentSecondaryBrush}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                              <StackPanel Grid.Column="1" Spacing="2">
                                                                  <TextBlock Text="{Binding Role}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextDisabledBrush}"/>
                                                                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
                                                              </StackPanel>
                                                          </Grid>
                                                     </Border>
                                                 </DataTemplate>
                                             </ItemsControl.ItemTemplate>
                                         </ItemsControl>
                                     </StackPanel>
                                     
                                     
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                         
                         <TabItem Header="{Binding [Lab_Tab_Chart], Source={x:Static svc:Loc.Instance}}" FontSize="12">
                             <Grid RowDefinitions="Auto, *">
                                 <Border Background="{DynamicResource SurfaceFloatingBrush}" Padding="12" Margin="16" CornerRadius="6">
                                      <TextBlock Text="{Binding [Odo_Title], Source={x:Static svc:Loc.Instance}}" Classes="label" FontWeight="SemiBold"/>
                                 </Border>
                                 <ScrollViewer Grid.Row="1" Padding="16">
                                      <local:OdontogramView DataContext="{Binding Odontogram}"/>
                                 </ScrollViewer>
                             </Grid>
                         </TabItem>
                         
                         <TabItem Header="{Binding [Lab_Tab_Flags], Source={x:Static svc:Loc.Instance}}" FontSize="12">
                             <ScrollViewer Padding="16">
                                 <ItemsControl ItemsSource="{Binding ForensicFlags}">
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Border Classes="card" Padding="12" Margin="0,4" BorderBrush="#40D83B01" BorderThickness="1" Background="#10D83B01">
                                                 <Grid ColumnDefinitions="Auto, *">
                                                     <PathIcon Data="{StaticResource IconWarning}" Foreground="{DynamicResource WarningBrush}" Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,2,12,0'}" VerticalAlignment="Top" Width="16" Height="16"/>
                                                     <StackPanel Grid.Column="1" Spacing="4">
                                                         <TextBlock Text="{Binding [Lab_Stats_Flags], Source={x:Static svc:Loc.Instance}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                                         <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                                     </StackPanel>
                                                 </Grid>
                                             </Border>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>
                             </ScrollViewer>
                         </TabItem>
                     </TabControl>
                     
                     <!-- Secure Action Footer -->
                     <Border Grid.Row="2" Background="{DynamicResource SurfaceFloatingBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="16">
                         <Button Command="{Binding SaveToSubjectCommand}" Classes="primary" HorizontalAlignment="Stretch" Padding="16,12" CornerRadius="8">
                             <StackPanel Orientation="Horizontal" Spacing="10">
                                 <PathIcon Data="{StaticResource IconCheckCircle}" Width="16" Height="16"/>
                                 <TextBlock Text="{Binding [Lab_Action_Save], Source={x:Static svc:Loc.Instance}}" FontWeight="SemiBold"/>
                             </StackPanel>
                         </Button>
                     </Border>
                 </Grid>
             </Border>
        </Grid>

        <!-- 5. SAVE DIALOG OVERLAY -->
        <Border Grid.RowSpan="2" IsVisible="{Binding IsSaveDialogOpen}" Background="#80000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid RowDefinitions="Auto, *">
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="32" Height="32" CornerRadius="6" Background="{DynamicResource AccentPrimaryBrush}">
                                <PathIcon Data="{StaticResource IconUser}" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding [Lab_Save_Title], Source={x:Static svc:Loc.Instance}}" Classes="h3"/>
                                <TextBlock Text="{Binding [Lab_Save_Subtitle], Source={x:Static svc:Loc.Instance}}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Content -->
                    <Border Grid.Row="1" Padding="24">
                        <StackPanel Spacing="16">
                        
                        <!-- Search Existing (To Link) -->
                        <Border Background="{DynamicResource SurfaceFloatingBrush}" CornerRadius="6" Padding="12" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                             <StackPanel Spacing="8">
                                 <TextBlock Text="{Binding [Lab_Save_Link], Source={x:Static svc:Loc.Instance}}" Classes="label"/>
                                 <AutoCompleteBox ItemsSource="{Binding Subjects}" 
                                                  SelectedItem="{Binding SelectedSubject}"
                                                  Watermark="{Binding [Lab_Save_LinkPlaceholder], Source={x:Static svc:Loc.Instance}}"
                                                  FilterMode="Contains"/>
                             </StackPanel>
                        </Border>

                        <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,8"/>
                        
                        <TextBlock Text="{Binding [Lab_Save_NewTitle], Source={x:Static svc:Loc.Instance}}" Classes="label" Foreground="{DynamicResource AccentPrimaryBrush}"/>

                        <!-- Subject Details Form -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [Lab_Save_Name], Source={x:Static svc:Loc.Instance}}" Classes="label"/>
                            <TextBox Text="{Binding NewSubjectName}" Watermark="{Binding [Lab_Save_NamePlaceholder], Source={x:Static svc:Loc.Instance}}" Classes="modern"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*, 16, *">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="{Binding [Lab_Save_Gender], Source={x:Static svc:Loc.Instance}}" Classes="label"/>
                                <ComboBox SelectedIndex="{Binding NewSubjectGenderIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" Classes="modern">
                                    <ComboBoxItem Content="{Binding [Lab_Save_Gender_Male], Source={x:Static svc:Loc.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Lab_Save_Gender_Female], Source={x:Static svc:Loc.Instance}}"/>
                                    <ComboBoxItem Content="{Binding [Lab_Save_Gender_Unknown], Source={x:Static svc:Loc.Instance}}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="{Binding [Lab_Save_NatID], Source={x:Static svc:Loc.Instance}}" Classes="label"/>
                                <TextBox Text="{Binding NewSubjectNationalId}" Watermark="{Binding [Lab_Save_Optional], Source={x:Static svc:Loc.Instance}}" Classes="modern"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding [Lab_Save_DOB], Source={x:Static svc:Loc.Instance}}" Classes="label"/>
                            <CalendarDatePicker SelectedDate="{Binding NewSubjectDob}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Actions -->
                        <Grid ColumnDefinitions="*, 16, *" Margin="0,16,0,0">
                            <Button Grid.Column="0" Command="{Binding CancelSaveCommand}" Content="{Binding [Lab_Save_Btn_Cancel], Source={x:Static svc:Loc.Instance}}" Classes="outline" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Command="{Binding ConfirmSaveNewSubjectCommand}" Content="{Binding [Lab_Save_Btn_Confirm], Source={x:Static svc:Loc.Instance}}" Classes="primary" HorizontalAlignment="Stretch"/>
                        </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>

    </Grid>

</UserControl>
