<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DentalID.Desktop.ViewModels"
             xmlns:svc="using:DentalID.Desktop.Services"
             xmlns:conv="using:DentalID.Desktop.Converters"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="380"
             x:Class="DentalID.Desktop.Views.OdontogramView"
             x:DataType="vm:OdontogramViewModel">

    <UserControl.Styles>
        <!-- Treatment palette items -->
        <Style Selector="Border.treatmentItem">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.treatmentItem:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.04)"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
        </Style>

        <!-- Tooth card container -->
        <Style Selector="Border.toothCard">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.toothCard:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.12)"/>
            <Setter Property="BoxShadow" Value="0 4 12 0 #30000000"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*, 200">
        <!-- Main Chart -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceFloatingBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                CornerRadius="12" Padding="16"
                Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='0,0,12,0'}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <DockPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10" DockPanel.Dock="Left">
                        <PathIcon Data="{StaticResource IconTooth}" Width="18" Height="18"
                                  Foreground="{DynamicResource AccentPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Str_Odo_Title}" FontWeight="Bold" FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="{DynamicResource Str_Odo_Reset}" Command="{Binding ResetCommand}"
                            Classes="outline" Padding="12,5" FontSize="11" DockPanel.Dock="Right"
                            HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- Chart Area -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBgBrush}"
                        CornerRadius="10" Padding="12" BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" HorizontalAlignment="Center"
                          VerticalAlignment="Center">

                        <!-- Upper Jaw Label -->
                        <TextBlock Grid.Row="0" Text="{DynamicResource Str_Odo_UpperJaw}"
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>

                        <!-- Upper Row: Q1 (18→11) | Q2 (21→28) -->
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" Margin="0,0,0,8">
                            <ItemsControl Grid.Column="0" ItemsSource="{Binding Quadrant1}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2"
                                                    HorizontalAlignment="Right"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ToothViewModel">
                                        <Border Classes="toothCard" CornerRadius="6" Padding="2"
                                                Background="Transparent"
                                                ToolTip.Tip="{Binding TooltipText}"
                                                DragDrop.AllowDrop="True"
                                                DragDrop.DragOver="OnToothDragOver"
                                                DragDrop.Drop="OnToothDrop"
                                                PointerPressed="OnToothTapped">
                                            <StackPanel Spacing="1" Width="38">
                                                <TextBlock Text="{Binding FdiNumber}" HorizontalAlignment="Center"
                                                           FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                           FontWeight="SemiBold"/>
                                                <Grid Width="34" Height="40">
                                                    <Path Data="{Binding Geometry}"
                                                          Fill="{Binding FillColor}"
                                                          Stroke="{Binding StrokeColor}"
                                                          StrokeThickness="{Binding StrokeThickness}"
                                                          Stretch="Uniform" Margin="2"/>
                                                    <!-- Missing X overlay -->
                                                    <Path Data="M0,0 L1,1 M1,0 L0,1" Stroke="#EF5350"
                                                          StrokeThickness="2.5" Stretch="Uniform" Margin="8"
                                                          IsVisible="{Binding IsMissing}" Opacity="0.8"/>
                                                    <!-- Status icon -->
                                                    <TextBlock Text="{Binding StatusIcon}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               FontSize="10" Margin="0,0,1,0"
                                                               Foreground="{Binding StatusIconColor}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Center Divider -->
                            <Border Grid.Column="1" Width="2" Margin="6,0"
                                    Background="{DynamicResource AccentPrimaryBrush}" Opacity="0.3"
                                    CornerRadius="1"/>

                            <ItemsControl Grid.Column="2" ItemsSource="{Binding Quadrant2}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2"
                                                    HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ToothViewModel">
                                        <Border Classes="toothCard" CornerRadius="6" Padding="2"
                                                Background="Transparent"
                                                ToolTip.Tip="{Binding TooltipText}"
                                                DragDrop.AllowDrop="True"
                                                DragDrop.DragOver="OnToothDragOver"
                                                DragDrop.Drop="OnToothDrop"
                                                PointerPressed="OnToothTapped">
                                            <StackPanel Spacing="1" Width="38">
                                                <TextBlock Text="{Binding FdiNumber}" HorizontalAlignment="Center"
                                                           FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                           FontWeight="SemiBold"/>
                                                <Grid Width="34" Height="40">
                                                    <Path Data="{Binding Geometry}"
                                                          Fill="{Binding FillColor}"
                                                          Stroke="{Binding StrokeColor}"
                                                          StrokeThickness="{Binding StrokeThickness}"
                                                          Stretch="Uniform" Margin="2"/>
                                                    <Path Data="M0,0 L1,1 M1,0 L0,1" Stroke="#EF5350"
                                                          StrokeThickness="2.5" Stretch="Uniform" Margin="8"
                                                          IsVisible="{Binding IsMissing}" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding StatusIcon}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               FontSize="10" Margin="0,0,1,0"
                                                               Foreground="{Binding StatusIconColor}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- Horizontal Jaw Divider -->
                        <Border Grid.Row="2" Height="2" Margin="8,0"
                                Background="{DynamicResource AccentPrimaryBrush}" Opacity="0.3"
                                CornerRadius="1"/>

                        <!-- Lower Row: Q4 (48→41) | Q3 (31→38) -->
                        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,*" Margin="0,8,0,0">
                            <ItemsControl Grid.Column="0" ItemsSource="{Binding Quadrant4}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2"
                                                    HorizontalAlignment="Right"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ToothViewModel">
                                        <Border Classes="toothCard" CornerRadius="6" Padding="2"
                                                Background="Transparent"
                                                ToolTip.Tip="{Binding TooltipText}"
                                                DragDrop.AllowDrop="True"
                                                DragDrop.DragOver="OnToothDragOver"
                                                DragDrop.Drop="OnToothDrop"
                                                PointerPressed="OnToothTapped">
                                            <StackPanel Spacing="1" Width="38">
                                                <Grid Width="34" Height="40">
                                                    <Path Data="{Binding Geometry}"
                                                          Fill="{Binding FillColor}"
                                                          Stroke="{Binding StrokeColor}"
                                                          StrokeThickness="{Binding StrokeThickness}"
                                                          Stretch="Uniform" Margin="2"/>
                                                    <Path Data="M0,0 L1,1 M1,0 L0,1" Stroke="#EF5350"
                                                          StrokeThickness="2.5" Stretch="Uniform" Margin="8"
                                                          IsVisible="{Binding IsMissing}" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding StatusIcon}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Top"
                                                               FontSize="10" Margin="0,0,1,0"
                                                               Foreground="{Binding StatusIconColor}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding FdiNumber}" HorizontalAlignment="Center"
                                                           FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Grid.Column="1" Width="2" Margin="6,0"
                                    Background="{DynamicResource AccentPrimaryBrush}" Opacity="0.3"
                                    CornerRadius="1"/>

                            <ItemsControl Grid.Column="2" ItemsSource="{Binding Quadrant3}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2"
                                                    HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ToothViewModel">
                                        <Border Classes="toothCard" CornerRadius="6" Padding="2"
                                                Background="Transparent"
                                                ToolTip.Tip="{Binding TooltipText}"
                                                DragDrop.AllowDrop="True"
                                                DragDrop.DragOver="OnToothDragOver"
                                                DragDrop.Drop="OnToothDrop"
                                                PointerPressed="OnToothTapped">
                                            <StackPanel Spacing="1" Width="38">
                                                <Grid Width="34" Height="40">
                                                    <Path Data="{Binding Geometry}"
                                                          Fill="{Binding FillColor}"
                                                          Stroke="{Binding StrokeColor}"
                                                          StrokeThickness="{Binding StrokeThickness}"
                                                          Stretch="Uniform" Margin="2"/>
                                                    <Path Data="M0,0 L1,1 M1,0 L0,1" Stroke="#EF5350"
                                                          StrokeThickness="2.5" Stretch="Uniform" Margin="8"
                                                          IsVisible="{Binding IsMissing}" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding StatusIcon}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Top"
                                                               FontSize="10" Margin="0,0,1,0"
                                                               Foreground="{Binding StatusIconColor}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding FdiNumber}" HorizontalAlignment="Center"
                                                           FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Legend -->
                <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#E8F0FE" BorderBrush="#90A4AE" BorderThickness="1"/>
                        <TextBlock Text="{DynamicResource Str_Odo_Healthy}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1.5"/>
                        <TextBlock Text="Detected" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#FFEBEE" BorderBrush="#EF5350" BorderThickness="1.5"/>
                        <TextBlock Text="{DynamicResource Str_Odo_Pathology}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#FFF8E1" BorderBrush="#FFC107" BorderThickness="1.5"/>
                        <TextBlock Text="Treatment" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Tools / Treatment Palette -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceFloatingBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                CornerRadius="12" Padding="14">
            <Grid RowDefinitions="Auto,Auto,*">
                <!-- Palette Header -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource IconAnalysis}" Width="14" Height="14"
                                  Foreground="{DynamicResource AccentSecondaryBrush}"/>
                        <TextBlock Text="{DynamicResource Str_Odo_Palette}" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource Str_Odo_DragHint}" FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"
                        Margin="0,10"/>

                <!-- Treatment List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Treatments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="treatmentItem"
                                        Background="{DynamicResource SurfaceBgBrush}"
                                        CornerRadius="8" Padding="10,8" Margin="0,3"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        PointerPressed="OnTreatmentPointerPressed">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Border Width="20" Height="20" CornerRadius="6"
                                                Background="{Binding Color}"
                                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                BorderThickness="1"/>
                                        <StackPanel Grid.Column="1"
                                                    Margin="{Binding IsRtl, Source={x:Static svc:Loc.Instance}, Converter={x:Static conv:BoolToMirroredThicknessConverter.Instance}, ConverterParameter='10,0,0,0'}">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding Category}" FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
